# ─── M2M Survey API – Environment Variables ───────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── Your API Key ──────────────────────────────────────────────────
# Generate any random 32-char hex string, e.g.:
#   node -e "console.log(require('crypto').randomBytes(16).toString('hex').toUpperCase())"
API_KEY=YOUR_NEW_API_KEY_HERE

# ── Zoho OAuth (from api-console.zoho.com → Self Client) ─────────
ZOHO_CLIENT_ID=1000.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ZOHO_CLIENT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ZOHO_REFRESH_TOKEN=1000.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Zoho Analytics IDs ────────────────────────────────────────────
# Org ID: Zoho Analytics → Settings → Organisation Profile
ZOHO_ORG_ID=XXXXXXXXXX

# Workspace ID + View ID: open your table in Zoho Analytics,
# copy from the URL: analytics.zoho.com/open-view/<WORKSPACE_ID>/<VIEW_ID>
ZOHO_WORKSPACE_ID=XXXXXXXXXXXXXXXXXX
ZOHO_VIEW_ID_PNP_FNB=XXXXXXXXXXXXXXXXXX

# ── Server ────────────────────────────────────────────────────────
PORT=3000
